{
  "name": "dh-portal-v2",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:build:mac": "tauri build --bundles app,dmg",
    "desktop:install:mac": "npm run desktop:build:mac && rm -rf '/Applications/DH Staff Portal.app' && ditto 'src-tauri/target/release/bundle/macos/DH Staff Portal.app' '/Applications/DH Staff Portal.app'",
    "docs:generate": "node scripts/generate-docs.mjs",
    "docs:check": "node scripts/generate-docs.mjs --check",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "security:check": "node scripts/security-check.mjs"
  },
  "dependencies": {
    "@azure/msal-browser": "^3.10.0",
    "@azure/msal-react": "^2.1.0",
    "@supabase/supabase-js": "^2.43.0",
    "dompurify": "^3.4.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.383.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.1"
  }
}
