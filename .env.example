# .env.example
# Copy this to .env.local for local development
# In production, set these in Cloudflare Pages → Settings → Environment Variables

# Microsoft Entra ID (Azure AD) — get these from portal.azure.com
VITE_AZURE_TENANT_ID=your-tenant-id-here
VITE_AZURE_CLIENT_ID=your-client-id-here

# Set to your Cloudflare Pages URL once deployed
# e.g. https://dh-portal.pages.dev  or  https://portal.dhwebsiteservices.co.uk
VITE_REDIRECT_URI=http://localhost:5173
