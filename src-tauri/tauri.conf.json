{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DH Staff Portal",
  "version": "1.0.0",
  "identifier": "uk.co.dhwebsiteservices.staffportal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DH Staff Portal",
        "url": "https://staff.dhwebsiteservices.co.uk",
        "userAgent": "DHStaffPortalDesktop/1.0 Safari/WebKit",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true,
        "acceptFirstMouse": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
